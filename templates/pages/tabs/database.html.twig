{#
 # CodexRoute - Pestaña de Rendimiento de Base de Datos
 #}

{% import 'components/alerts_macros.html.twig' as alerts %}

<div class="tab-pane fade show active" id="database-tab">
    <div class="card mb-3">
        <div class="card-header">
            <h3 class="card-title mb-0">
                <i class="ti ti-database"></i> 
                {{ __('Estado de la Base de Datos', 'codexroute') }}
            </h3>
        </div>
        <div class="card-body">
            {% if not db_status.connected %}
                {{ alerts.alert_danger(
                    __('Error de Conexión:', 'codexroute'),
                    db_status.error|default('No se pudo conectar')
                ) }}
            {% else %}
                <div class="row g-3 mb-4">
                    <div class="col-lg-3 col-md-6 col-sm-6">
                        <div class="card border-0 shadow-sm h-100 border-start border-info border-4">
                            <div class="card-body p-3">
                                <div class="d-flex align-items-start mb-3">
                                    <div class="flex-shrink-0">
                                        <div class="bg-info text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 64px; height: 64px;">
                                            <i class="ti ti-server" style="font-size: 1.75rem;"></i>
                                        </div>
                                    </div>
                                    <div class="flex-grow-1 ms-3">
                                        <div class="text-dark fw-semibold mb-1" style="font-size: 0.875rem; line-height: 1.3;">{{ __('Host', 'codexroute') }}</div>
                                        <div class="mb-0 text-info fw-bold" style="font-size: 1.25rem; line-height: 1.2; word-break: break-word;">{{ db_status.host|e }}</div>
                                    </div>
                                </div>
                                <div class="text-muted" style="font-size: 0.8rem; line-height: 1.4;">
                                    <i class="ti ti-info-circle"></i> 
                                    <span>{{ __('Servidor de base de datos', 'codexroute') }}</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="col-lg-3 col-md-6 col-sm-6">
                        <div class="card border-0 shadow-sm h-100 border-start border-primary border-4">
                            <div class="card-body p-3">
                                <div class="d-flex align-items-start mb-3">
                                    <div class="flex-shrink-0">
                                        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 64px; height: 64px;">
                                            <i class="ti ti-database" style="font-size: 1.75rem;"></i>
                                        </div>
                                    </div>
                                    <div class="flex-grow-1 ms-3">
                                        <div class="text-dark fw-semibold mb-1" style="font-size: 0.875rem; line-height: 1.3;">{{ __('Base de Datos', 'codexroute') }}</div>
                                        <div class="mb-0 text-primary fw-bold" style="font-size: 1.25rem; line-height: 1.2; word-break: break-word;">{{ db_status.database|e }}</div>
                                    </div>
                                </div>
                                <div class="text-muted" style="font-size: 0.8rem; line-height: 1.4;">
                                    <i class="ti ti-info-circle"></i> 
                                    <span>{{ __('Nombre de la base de datos', 'codexroute') }}</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="col-lg-3 col-md-6 col-sm-6">
                        <div class="card border-0 shadow-sm h-100 border-start border-{{ db_status.status == 'ok' ? 'success' : 'warning' }} border-4">
                            <div class="card-body p-3">
                                <div class="d-flex align-items-start mb-3">
                                    <div class="flex-shrink-0">
                                        <div class="bg-{{ db_status.status == 'ok' ? 'success' : 'warning' }} text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 64px; height: 64px;">
                                            <i class="ti ti-clock" style="font-size: 1.75rem;"></i>
                                        </div>
                                    </div>
                                    <div class="flex-grow-1 ms-3">
                                        <div class="text-dark fw-semibold mb-1" style="font-size: 0.875rem; line-height: 1.3;">{{ __('Consulta Simple', 'codexroute') }}</div>
                                        <div class="mb-0 text-{{ db_status.status == 'ok' ? 'success' : 'warning' }} fw-bold" style="font-size: 1.5rem; line-height: 1.2;">
                                            {{ (db_status.simple_query_time * 1000)|number_format(2) }} ms
                                        </div>
                                    </div>
                                </div>
                                <div class="text-muted" style="font-size: 0.8rem; line-height: 1.4;">
                                    <i class="ti ti-{{ db_status.status == 'ok' ? 'check' : 'alert-triangle' }}"></i> 
                                    <span>{{ db_status.status == 'ok' ? __('Rendimiento óptimo', 'codexroute') : __('Rendimiento lento', 'codexroute') }}</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="col-lg-3 col-md-6 col-sm-6">
                        <div class="card border-0 shadow-sm h-100 border-start border-success border-4">
                            <div class="card-body p-3">
                                <div class="d-flex align-items-start mb-3">
                                    <div class="flex-shrink-0">
                                        <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 64px; height: 64px;">
                                            <i class="ti ti-plug" style="font-size: 1.75rem;"></i>
                                        </div>
                                    </div>
                                    <div class="flex-grow-1 ms-3">
                                        <div class="text-dark fw-semibold mb-1" style="font-size: 0.875rem; line-height: 1.3;">{{ __('Estado', 'codexroute') }}</div>
                                        <div class="mb-0 text-success fw-bold" style="font-size: 1.25rem; line-height: 1.2;">
                                            {{ __('Conectado', 'codexroute') }}
                                        </div>
                                    </div>
                                </div>
                                <div class="text-muted" style="font-size: 0.8rem; line-height: 1.4;">
                                    <i class="ti ti-check"></i> 
                                    <span>{{ __('Conexión activa', 'codexroute') }}</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
    
    <div class="card mb-3">
        <div class="card-header">
            <h3 class="card-title mb-0">{{ __('Acciones de Análisis', 'codexroute') }}</h3>
        </div>
        <div class="card-body">
            <div class="d-flex gap-2 flex-wrap">
                <button class="btn btn-primary" 
                        onclick="executeAction('analyze_database')" 
                        {{ not db_status.connected ? 'disabled' : '' }}>
                    <i class="ti ti-chart-bar"></i> {{ __('Analizar BD', 'codexroute') }}
                </button>
                <button class="btn btn-success" 
                        onclick="executeAction('profile_sql')" 
                        {{ not db_status.connected ? 'disabled' : '' }}>
                    <i class="ti ti-search"></i> {{ __('Profiling SQL', 'codexroute') }}
                </button>
                <button class="btn btn-info" 
                        onclick="executeAction('analyze_views')" 
                        {{ not db_status.connected ? 'disabled' : '' }}>
                    <i class="ti ti-eye"></i> {{ __('Analizar Vistas', 'codexroute') }}
                </button>
            </div>
        </div>
    </div>
    
    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h3 class="card-title mb-0">
                <i class="ti ti-wand"></i> 
                {{ __('Optimización de Tablas', 'codexroute') }}
            </h3>
            <div class="d-flex gap-2">
                <div class="input-group input-group-sm" style="max-width: 250px;">
                    <span class="input-group-text"><i class="ti ti-search"></i></span>
                    <input type="text" 
                           class="form-control" 
                           id="tables-search" 
                           placeholder="{{ __('Buscar tabla...', 'codexroute') }}"
                           onkeyup="filterTables()">
                </div>
            </div>
        </div>
        <div class="card-body">
            {% if optimizable_tables is empty %}
                <div class="text-center py-5">
                    <i class="ti ti-inbox fs-1 text-muted mb-3"></i>
                    <p class="text-muted">{{ __('No hay tablas optimizables configuradas', 'codexroute') }}</p>
                </div>
            {% else %}
                <div class="table-responsive">
                    <table class="table table-hover" id="optimizable-tables-table">
                        <thead>
                            <tr>
                                <th style="width: 4%; min-width: 40px;">#</th>
                                <th style="width: 30%;">{{ __('Tabla', 'codexroute') }}</th>
                                <th style="width: 50%;">{{ __('Descripción', 'codexroute') }}</th>
                                <th style="width: 16%; min-width: 100px;" class="text-center">{{ __('Acciones', 'codexroute') }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for name, config in optimizable_tables %}
                            <tr class="table-row" 
                                data-name="{{ name|lower|e }}"
                                data-table="{{ config.table|lower|e }}">
                                <td class="text-muted">{{ loop.index }}</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <i class="ti ti-{{ config.icon }} text-primary me-2"></i>
                                        <div>
                                            <strong>{{ name|e }}</strong><br>
                                            <small><code class="text-muted">{{ config.table|e }}</code></small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="text-muted">{{ config.description|e }}</span>
                                </td>
                                <td class="text-center">
                                    <button class="btn btn-sm btn-primary" 
                                            onclick="optimizeTable('{{ name|e('js') }}', '{{ config.table|e('js') }}')"
                                            title="{{ __('Optimizar esta tabla', 'codexroute') }}">
                                        <i class="ti ti-wand"></i> {{ __('Optimizar', 'codexroute') }}
                                    </button>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                <div class="mt-3 pt-3 border-top">
                    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-start align-items-lg-center gap-3">
                        <div class="flex-grow-1" style="min-width: 0; writing-mode: horizontal-tb !important; text-orientation: mixed !important; direction: ltr !important;">
                            <div class="text-muted small mb-1" id="tables-footer-text" style="writing-mode: horizontal-tb !important; text-orientation: mixed !important; direction: ltr !important; white-space: nowrap !important; display: inline-block !important; width: 100%; max-width: 100%; overflow: visible !important;">
                                <span id="tables-count" style="display: inline !important; white-space: normal !important;">{{ optimizable_tables|length }}</span> 
                                <span style="display: inline !important; white-space: normal !important;">{{ __('de', 'codexroute') }}</span> 
                                <strong style="display: inline !important; white-space: normal !important;">{{ optimizable_tables|length }}</strong> 
                                <span style="display: inline !important; white-space: normal !important;">{{ __('tablas', 'codexroute') }}</span>
                            </div>
                            <div id="tables-pagination-info" class="text-muted small" style="display: none; writing-mode: horizontal-tb !important; text-orientation: mixed !important; direction: ltr !important; white-space: nowrap !important; display: inline-block !important; width: 100%; max-width: 100%; overflow: visible !important;">
                                <span style="display: inline !important; white-space: normal !important;">{{ __('Mostrando', 'codexroute') }}</span> 
                                <span id="tables-page-start" style="display: inline !important; white-space: normal !important;">1</span>
                                <span style="display: inline !important; white-space: normal !important;">-</span>
                                <span id="tables-page-end" style="display: inline !important; white-space: normal !important;">{{ optimizable_tables|length }}</span> 
                                <span style="display: inline !important; white-space: normal !important;">{{ __('de', 'codexroute') }}</span> 
                                <strong id="tables-total-filtered" style="display: inline !important; white-space: normal !important;">{{ optimizable_tables|length }}</strong>
                            </div>
                        </div>
                        <div class="flex-shrink-0" style="writing-mode: horizontal-tb !important; text-orientation: mixed !important; direction: ltr !important;">
                            <nav aria-label="{{ __('Paginación de tablas', 'codexroute') }}" style="writing-mode: horizontal-tb !important; text-orientation: mixed !important; direction: ltr !important;">
                                <ul class="pagination pagination-sm mb-0" id="optimizable-tables-pagination" style="writing-mode: horizontal-tb !important; text-orientation: mixed !important; direction: ltr !important;">
                                </ul>
                            </nav>
                        </div>
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
    
    <div class="card" id="database-results" style="display: none;">
        <div class="card-header">
            <h3 class="card-title mb-0">{{ __('Resultados', 'codexroute') }}</h3>
        </div>
        <div class="card-body" id="database-results-content">
        </div>
    </div>
</div>

<script>
// Funciones para Optimización de Tablas
let tablesAllRows = [];
let tablesCurrentPage = 1;
const tablesItemsPerPage = 20;
let tablesAllVisibleRows = [];

function filterTables() {
    const searchTerm = document.getElementById('tables-search')?.value.toLowerCase() || '';
    
    if (tablesAllRows.length === 0) {
        tablesAllRows = Array.from(document.querySelectorAll('#optimizable-tables-table tbody .table-row'));
    }
    
    tablesAllRows.forEach(row => {
        row.style.display = 'none';
    });
    
    tablesAllVisibleRows = [];
    
    tablesAllRows.forEach((row) => {
        const name = (row.dataset.name || '').toLowerCase();
        const table = (row.dataset.table || '').toLowerCase();
        
        const matchesSearch = searchTerm === '' || name.includes(searchTerm) || table.includes(searchTerm);
        
        if (matchesSearch) {
            tablesAllVisibleRows.push(row);
        }
    });
    
    tablesCurrentPage = 1;
    updateTablesPagination();
    displayTablesPage();
}

function displayTablesPage() {
    const start = (tablesCurrentPage - 1) * tablesItemsPerPage;
    const end = start + tablesItemsPerPage;
    
    tablesAllVisibleRows.forEach((row, index) => {
        if (index >= start && index < end) {
            row.style.display = '';
        } else {
            row.style.display = 'none';
        }
    });
    
    const pageStart = tablesAllVisibleRows.length > 0 ? start + 1 : 0;
    const pageEnd = Math.min(end, tablesAllVisibleRows.length);
    
    const countEl = document.getElementById('tables-count');
    const startEl = document.getElementById('tables-page-start');
    const endEl = document.getElementById('tables-page-end');
    const totalEl = document.getElementById('tables-total-filtered');
    const infoEl = document.getElementById('tables-pagination-info');
    
    if (countEl) countEl.textContent = tablesAllVisibleRows.length;
    if (startEl) startEl.textContent = pageStart;
    if (endEl) endEl.textContent = pageEnd;
    if (totalEl) totalEl.textContent = tablesAllVisibleRows.length;
    
    if (infoEl) {
        if (tablesAllVisibleRows.length > tablesItemsPerPage) {
            infoEl.style.display = 'block';
        } else {
            infoEl.style.display = 'none';
        }
    }
}

function updateTablesPagination() {
    const totalPages = Math.ceil(tablesAllVisibleRows.length / tablesItemsPerPage);
    const pagination = document.getElementById('optimizable-tables-pagination');
    if (!pagination) return;
    
    pagination.innerHTML = '';
    
    if (totalPages <= 1) {
        return;
    }
    
    const prevLi = document.createElement('li');
    prevLi.className = `page-item ${tablesCurrentPage === 1 ? 'disabled' : ''}`;
    prevLi.innerHTML = `<a class="page-link" href="#" onclick="goToTablesPage(${tablesCurrentPage - 1}); return false;">
        <i class="ti ti-chevron-left"></i> <span class="d-none d-sm-inline">Anterior</span>
    </a>`;
    pagination.appendChild(prevLi);
    
    const maxVisible = 5;
    let startPage = Math.max(1, tablesCurrentPage - Math.floor(maxVisible / 2));
    let endPage = Math.min(totalPages, startPage + maxVisible - 1);
    
    if (endPage - startPage < maxVisible - 1) {
        startPage = Math.max(1, endPage - maxVisible + 1);
    }
    
    if (startPage > 1) {
        const firstLi = document.createElement('li');
        firstLi.className = 'page-item';
        firstLi.innerHTML = `<a class="page-link" href="#" onclick="goToTablesPage(1); return false;">1</a>`;
        pagination.appendChild(firstLi);
        
        if (startPage > 2) {
            const dotsLi = document.createElement('li');
            dotsLi.className = 'page-item disabled';
            dotsLi.innerHTML = `<span class="page-link">...</span>`;
            pagination.appendChild(dotsLi);
        }
    }
    
    for (let i = startPage; i <= endPage; i++) {
        const li = document.createElement('li');
        li.className = `page-item ${i === tablesCurrentPage ? 'active' : ''}`;
        li.innerHTML = `<a class="page-link" href="#" onclick="goToTablesPage(${i}); return false;">${i}</a>`;
        pagination.appendChild(li);
    }
    
    if (endPage < totalPages) {
        if (endPage < totalPages - 1) {
            const dotsLi = document.createElement('li');
            dotsLi.className = 'page-item disabled';
            dotsLi.innerHTML = `<span class="page-link">...</span>`;
            pagination.appendChild(dotsLi);
        }
        
        const lastLi = document.createElement('li');
        lastLi.className = 'page-item';
        lastLi.innerHTML = `<a class="page-link" href="#" onclick="goToTablesPage(${totalPages}); return false;">${totalPages}</a>`;
        pagination.appendChild(lastLi);
    }
    
    const nextLi = document.createElement('li');
    nextLi.className = `page-item ${tablesCurrentPage === totalPages ? 'disabled' : ''}`;
    nextLi.innerHTML = `<a class="page-link" href="#" onclick="goToTablesPage(${tablesCurrentPage + 1}); return false;">
        <span class="d-none d-sm-inline">Siguiente</span> <i class="ti ti-chevron-right"></i>
    </a>`;
    pagination.appendChild(nextLi);
}

function goToTablesPage(page) {
    const totalPages = Math.ceil(tablesAllVisibleRows.length / tablesItemsPerPage);
    if (page < 1 || page > totalPages) return;
    tablesCurrentPage = page;
    displayTablesPage();
    updateTablesPagination();
}

// Inicialización
document.addEventListener('DOMContentLoaded', function() {
    if (document.getElementById('optimizable-tables-table')) {
        tablesAllRows = Array.from(document.querySelectorAll('#optimizable-tables-table tbody .table-row'));
        filterTables();
    }
});
</script>

