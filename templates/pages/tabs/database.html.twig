{#
 # CodexRoute - Pestaña de Rendimiento de Base de Datos
 # Listados alineados con búsqueda nativa GLPI (search_page, search-card, card-table, pager).
 #}

{% import 'components/alerts_macros.html.twig' as alerts %}

<script>window.codexrouteGlpiListLimit = {{ glpi_list_limit|default(20) }};</script>
{% include '@codexroute/components/codexroute_glpi_list_helpers.html.twig' %}

<div class="codexroute-plugin-pane codexroute-tab-pane d-flex flex-column gap-3" id="database-tab">
    <div class="search_page codexroute-embedded-search">
        <div class="search-container disable-overflow-y">
            <div class="card card-sm mt-0 search-card">
                <div class="card-header d-flex justify-content-between search-header pe-0 flex-wrap align-items-center gap-2 py-2">
                    <h3 class="card-title mb-0 fs-5">{{ __('Estado de la Base de Datos', 'codexroute') }}</h3>
                </div>
                {% if not db_status.connected %}
                    <div class="p-3">
                        {{ alerts.alert_danger(
                            __('Error de Conexión:', 'codexroute'),
                            db_status.error|default('No se pudo conectar')
                        ) }}
                    </div>
                {% else %}
                    <div class="table-responsive-lg">
                        <table class="table card-table table-hover mb-0">
                            <tbody>
                                <tr>
                                    <th class="w-25 text-muted fw-normal">{{ __('Host', 'codexroute') }}</th>
                                    <td><span class="text-break">{{ db_status.host|e }}</span></td>
                                </tr>
                                <tr>
                                    <th class="text-muted fw-normal">{{ __('Base de Datos', 'codexroute') }}</th>
                                    <td><span class="text-break text-muted">{{ db_status.database|e }}</span></td>
                                </tr>
                                <tr>
                                    <th class="text-muted fw-normal">{{ __('Consulta Simple', 'codexroute') }}</th>
                                    <td>{{ (db_status.simple_query_time * 1000)|number_format(2) }} ms</td>
                                </tr>
                                <tr>
                                    <th class="text-muted fw-normal">{{ __('Estado', 'codexroute') }}</th>
                                    <td>
                                        {% if db_status.status == 'ok' %}
                                            <span class="text-success fw-medium">{{ __('Conectado', 'codexroute') }}</span>
                                        {% else %}
                                            <span class="text-warning fw-medium">{{ __('Rendimiento lento', 'codexroute') }}</span>
                                        {% endif %}
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>

    <div class="card card-sm mt-0">
        <div class="card-header d-flex justify-content-between search-header pe-0 py-2">
            <h3 class="card-title mb-0 fs-5">{{ __('Acciones de Análisis', 'codexroute') }}</h3>
        </div>
        <div class="card-body">
            <div class="d-flex gap-2 flex-wrap">
                <button type="button" class="btn btn-primary"
                        onclick="executeAction('analyze_database', {}, this)"
                        {{ not db_status.connected ? 'disabled' : '' }}>
                    {{ __('Analizar BD', 'codexroute') }}
                </button>
                <button type="button" class="btn btn-outline-secondary"
                        onclick="executeAction('profile_sql', {}, this)"
                        {{ not db_status.connected ? 'disabled' : '' }}>
                    {{ __('Profiling SQL', 'codexroute') }}
                </button>
                <button type="button" class="btn btn-outline-secondary"
                        onclick="executeAction('analyze_views', {}, this)"
                        {{ not db_status.connected ? 'disabled' : '' }}>
                    {{ __('Analizar Vistas', 'codexroute') }}
                </button>
            </div>
        </div>
    </div>

    <div class="search_page codexroute-embedded-search">
        <div class="search-container disable-overflow-y">
            <div class="card card-sm mt-0 search-card">
            {% if optimizable_tables is empty %}
                <div class="alert alert-info mb-0 rounded-0 border-top-0 border-bottom-0 border-end-0" role="alert">
                    {{ __('No hay tablas optimizables configuradas', 'codexroute') }}
                </div>
            {% else %}
                <div class="card-header d-flex justify-content-between search-header pe-0 flex-wrap align-items-center gap-2 py-2">
                    <h3 class="card-title mb-0 fs-5">{{ __('Optimización de Tablas', 'codexroute') }}</h3>
                    <div class="input-group input-group-sm flex-grow-1 flex-sm-grow-0 ms-lg-auto" style="min-width: 12rem; max-width: 100%;">
                        <span class="input-group-text" aria-hidden="true"><i class="ti ti-search"></i></span>
                        <input type="text"
                               class="form-control"
                               id="tables-search"
                               placeholder="{{ __('Buscar tabla...', 'codexroute') }}"
                               onkeyup="filterTables()">
                    </div>
                </div>
                <div class="table-responsive-lg">
                    <table class="search-results table card-table table-hover table-striped align-middle mb-0" id="optimizable-tables-table">
                        <thead>
                            <tr>
                                <th style="width: 4%; min-width: 40px;">#</th>
                                <th style="width: 30%;">{{ __('Tabla', 'codexroute') }}</th>
                                <th style="width: 50%;">{{ __('Descripción', 'codexroute') }}</th>
                                <th style="width: 16%; min-width: 100px;" class="text-center">{{ __('Acciones', 'codexroute') }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for name, config in optimizable_tables %}
                            <tr class="table-row"
                                data-name="{{ name|lower|e }}"
                                data-table="{{ config.table|lower|e }}">
                                <td class="text-muted">{{ loop.index }}</td>
                                <td>
                                    <span class="fw-medium text-break d-block">{{ name|e }}</span>
                                    <small class="text-muted text-break d-block">{{ config.table|e }}</small>
                                </td>
                                <td>
                                    <span class="text-muted">{{ config.description|e }}</span>
                                </td>
                                <td class="text-center text-nowrap">
                                    <button type="button" class="btn btn-sm btn-primary"
                                            onclick="optimizeTable('{{ name|e('js') }}', '{{ config.table|e('js') }}', this)"
                                            title="{{ __('Optimizar esta tabla', 'codexroute') }}">
                                        {{ __('Optimizar', 'codexroute') }}
                                    </button>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                <div class="card-footer search-footer">
                    {% include '@codexroute/components/codexroute_search_pager.html.twig' with {
                        prefix: 'codexroute-opt-tables',
                        limit_select_extra_class: 'codexroute-limit-opt-tables',
                        pagination_ul_id: 'codexroute-opt-tables-pagination'
                    } %}
                </div>
            {% endif %}
            </div>
        </div>
    </div>

    <div class="card card-sm mt-0 d-none" id="database-results">
        <div class="card-header d-flex justify-content-between search-header pe-0 py-2">
            <h3 class="card-title mb-0 fs-5">{{ __('Resultados', 'codexroute') }}</h3>
        </div>
        <div class="card-body p-0" id="database-results-content"></div>
    </div>
</div>

<script>
let tablesAllRows = [];
let tablesCurrentPage = 1;
let tablesAllVisibleRows = [];

function filterTables() {
    const searchTerm = document.getElementById('tables-search')?.value.toLowerCase() || '';

    if (tablesAllRows.length === 0) {
        tablesAllRows = Array.from(document.querySelectorAll('#optimizable-tables-table tbody .table-row'));
    }

    tablesAllRows.forEach((row) => {
        row.style.display = 'none';
    });

    tablesAllVisibleRows = [];

    tablesAllRows.forEach((row) => {
        const name = (row.dataset.name || '').toLowerCase();
        const table = (row.dataset.table || '').toLowerCase();
        const matchesSearch = searchTerm === '' || name.includes(searchTerm) || table.includes(searchTerm);
        if (matchesSearch) {
            tablesAllVisibleRows.push(row);
        }
    });

    tablesCurrentPage = 1;
    updateTablesPagination();
    displayTablesPage();
}

function displayTablesPage() {
    const limit = window.codexrouteGetPageSizeForTable('optimizable-tables-table');
    const start = (tablesCurrentPage - 1) * limit;
    const end = start + limit;
    const total = tablesAllVisibleRows.length;

    tablesAllVisibleRows.forEach((row, index) => {
        row.style.display = (index >= start && index < end) ? '' : 'none';
    });

    if (total === 0) {
        window.codexrouteFillPageInfos('codexroute-opt-tables', 0, 0, 0);
    } else {
        const pageStart = start + 1;
        const pageEnd = Math.min(end, total);
        window.codexrouteFillPageInfos('codexroute-opt-tables', pageStart, pageEnd, total);
    }
}

function updateTablesPagination() {
    const limit = window.codexrouteGetPageSizeForTable('optimizable-tables-table');
    const total = tablesAllVisibleRows.length;
    const totalPages = Math.max(1, Math.ceil(total / limit));
    if (tablesCurrentPage > totalPages) {
        tablesCurrentPage = totalPages;
    }
    window.codexrouteRenderGlpiPager(
        'codexroute-opt-tables-pagination',
        tablesCurrentPage,
        totalPages,
        limit,
        'goToTablesPage'
    );
}

function goToTablesPage(page) {
    const limit = window.codexrouteGetPageSizeForTable('optimizable-tables-table');
    const totalPages = Math.max(1, Math.ceil(tablesAllVisibleRows.length / limit));
    if (page < 1 || page > totalPages) {
        return;
    }
    tablesCurrentPage = page;
    displayTablesPage();
    updateTablesPagination();
}

function onCodexrouteOptTablesLimitChange(ev) {
    if (!ev.target.classList.contains('search-limit-dropdown')) {
        return;
    }
    const table = ev.target.closest('.search-card')?.querySelector('#optimizable-tables-table');
    if (!table) {
        return;
    }
    const limit = parseInt(ev.target.value, 10) || 20;
    const totalPages = Math.max(1, Math.ceil(tablesAllVisibleRows.length / limit));
    if (tablesCurrentPage > totalPages) {
        tablesCurrentPage = totalPages;
    }
    updateTablesPagination();
    displayTablesPage();
}

document.addEventListener('DOMContentLoaded', function() {
    document.getElementById('database-tab')?.addEventListener('change', onCodexrouteOptTablesLimitChange);

    if (document.getElementById('optimizable-tables-table')) {
        tablesAllRows = Array.from(document.querySelectorAll('#optimizable-tables-table tbody .table-row'));
        filterTables();
    }
});
</script>
