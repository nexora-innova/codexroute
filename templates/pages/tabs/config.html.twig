{#
 # CodexRoute - Pestaña de Configuración de Encriptación (layout alineado con formularios nativos GLPI)
 #}

{% import 'components/form/fields_macros.html.twig' as fields %}
{% import 'components/alerts_macros.html.twig' as alerts %}

<div class="codexroute-plugin-pane codexroute-tab-pane" id="config-tab">
    <div class="card card-sm mb-0">
        <div class="card-body">
            {% if config_file_exists %}
                {{ alerts.alert_success(
                    __('Archivo de configuración generado', 'codexroute'),
                    __('El archivo de configuración ya existe. Los cambios que guardes se reflejarán automáticamente en el archivo.', 'codexroute')
                ) }}
            {% else %}
                {{ alerts.alert_info(
                    __('Información:', 'codexroute'),
                    [
                        __('Configura los valores y luego genera el archivo de configuración.', 'codexroute'),
                        __('Una vez generado, los cambios que guardes se actualizarán automáticamente en el archivo.', 'codexroute')
                    ]
                ) }}
            {% endif %}

            <form id="encryption-config-form" method="post" action="">
                <h4 class="mb-3 pb-2 border-bottom text-muted text-uppercase fs-6 fw-semibold">
                    <i class="ti ti-shield me-2"></i>{{ __('Seguridad', 'codexroute') }}
                </h4>
                <div class="row flex-row mb-4">
                    <div class="col-12 col-xxl-10">
                        {{ fields.checkboxField(
                            'encryption_enabled',
                            encryption_config.encryption_enabled ? 1 : 0,
                            __('Activar Encriptación de IDs', 'codexroute'),
                            {
                                'add_field_html': '<small class="form-text text-muted d-block mt-1">' ~ __('Encripta los IDs numéricos en todas las URLs. Desactiva para deshabilitar completamente la encriptación.', 'codexroute') ~ '</small>',
                                'full_width': true,
                                'mb': 'mb-3'
                            }
                        ) }}

                        {{ fields.checkboxField(
                            'strict_mode',
                            encryption_config.strict_mode ? 1 : 0,
                            __('Modo Estricto', 'codexroute'),
                            {
                                'add_field_html': '<small class="form-text text-muted d-block mt-1">' ~ __('Rechaza IDs numéricos sin encriptar.', 'codexroute') ~ '</small>',
                                'full_width': true,
                                'mb': 'mb-3'
                            }
                        ) }}

                        {{ fields.checkboxField(
                            'log_numeric_ids',
                            encryption_config.log_numeric_ids ? 1 : 0,
                            __('Registrar IDs Numéricos', 'codexroute'),
                            {
                                'add_field_html': '<small class="form-text text-muted d-block mt-1">' ~ __('Registra en logs cuando se recibe un ID sin encriptar.', 'codexroute') ~ '</small>',
                                'full_width': true,
                                'mb': 'mb-3'
                            }
                        ) }}

                        {{ fields.checkboxField(
                            'log_security',
                            encryption_config.log_security ? 1 : 0,
                            __('Registrar Eventos de Seguridad', 'codexroute'),
                            {
                                'add_field_html': '<small class="form-text text-muted d-block mt-1">' ~ __('Registra eventos de seguridad en los logs.', 'codexroute') ~ '</small>',
                                'full_width': true,
                                'mb': 'mb-0'
                            }
                        ) }}
                    </div>
                </div>

                <h4 class="mb-3 pb-2 border-bottom text-muted text-uppercase fs-6 fw-semibold">
                    <i class="ti ti-gauge me-2"></i>{{ __('Rendimiento', 'codexroute') }}
                </h4>
                <div class="row flex-row mb-4">
                    <div class="col-12 col-md-6 col-xxl-5">
                        {{ fields.numberField(
                            'cache_size',
                            encryption_config.cache_size,
                            __('Tamaño Máximo del Caché', 'codexroute'),
                            {
                                'min': 50,
                                'max': 500,
                                'step': 1,
                                'add_field_html': '<small class="form-text text-muted">' ~ __('Número máximo de entradas en el caché. Valores recomendados: 50-200', 'codexroute') ~ '</small>',
                                'full_width': true,
                                'mb': 'mb-3'
                            }
                        ) }}
                    </div>
                    <div class="col-12 col-md-6 col-xxl-5">
                        {{ fields.numberField(
                            'cache_ttl',
                            encryption_config.cache_ttl,
                            __('TTL del Caché (segundos)', 'codexroute'),
                            {
                                'min': 60,
                                'max': 3600,
                                'step': 60,
                                'add_field_html': '<small class="form-text text-muted">' ~ __('Tiempo de vida de las entradas del caché.', 'codexroute') ~ '</small>',
                                'full_width': true,
                                'mb': 'mb-0'
                            }
                        ) }}
                    </div>
                </div>

                <h4 class="mb-3 pb-2 border-bottom text-muted text-uppercase fs-6 fw-semibold">
                    <i class="ti ti-ban me-2"></i>{{ __('Protección contra Ataques', 'codexroute') }}
                </h4>
                <div class="row flex-row mb-2">
                    <div class="col-12 col-md-6 col-xxl-5">
                        {{ fields.numberField(
                            'block_after_attempts',
                            encryption_config.block_after_attempts,
                            __('Bloquear IP después de intentos', 'codexroute'),
                            {
                                'min': 5,
                                'max': 100,
                                'step': 1,
                                'add_field_html': '<small class="form-text text-muted">' ~ __('Número de intentos fallidos antes de bloquear una IP.', 'codexroute') ~ '</small>',
                                'full_width': true,
                                'mb': 'mb-3'
                            }
                        ) }}
                    </div>
                    <div class="col-12 col-md-6 col-xxl-5">
                        {{ fields.numberField(
                            'block_duration',
                            encryption_config.block_duration,
                            __('Duración del Bloqueo (segundos)', 'codexroute'),
                            {
                                'min': 300,
                                'max': 86400,
                                'step': 300,
                                'add_field_html': '<small class="form-text text-muted">' ~ __('Tiempo que una IP permanece bloqueada.', 'codexroute') ~ '</small>',
                                'full_width': true,
                                'mb': 'mb-0'
                            }
                        ) }}
                    </div>
                </div>

                <div class="d-flex flex-wrap gap-2 mt-4 pt-3 border-top">
                    <button type="button" class="btn btn-primary" onclick="saveEncryptionConfig()" id="btn-save-config">
                        <i class="ti ti-device-floppy me-1"></i>{{ __('Guardar Configuración', 'codexroute') }}
                    </button>
                    <button type="button"
                            class="btn btn-outline-secondary"
                            onclick="generateConfigFile()"
                            id="btn-generate-config">
                        <i class="ti ti-file-code me-1"></i>
                        {% if config_file_exists %}
                            {{ __('Regenerar Archivo de Configuración', 'codexroute') }}
                        {% else %}
                            {{ __('Generar Archivo de Configuración', 'codexroute') }}
                        {% endif %}
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
