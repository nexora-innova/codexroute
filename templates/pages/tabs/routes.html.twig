{#
 # CodexRoute - Pestaña de Permisos de Rutas
 #}

{% import 'components/alerts_macros.html.twig' as alerts %}

<div class="tab-pane fade show active" id="routes-tab">
    <div class="card mb-3">
        <div class="card-header">
            <h3 class="card-title mb-0">{{ __('Gestión de Permisos de Rutas', 'codexroute') }}</h3>
        </div>
        <div class="card-body">
            {{ alerts.alert_info(
                __('Información:', 'codexroute'),
                __('Esta sección permite corregir los permisos de rutas que están siendo bloqueadas con error 403.', 'codexroute')
            ) }}
        </div>
    </div>
    
    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h3 class="card-title mb-0">
                <i class="ti ti-alert-triangle"></i> 
                {{ __('Rutas Problemáticas', 'codexroute') }}
            </h3>
            <div class="d-flex gap-2">
                <div class="input-group input-group-sm" style="max-width: 250px;">
                    <span class="input-group-text"><i class="ti ti-search"></i></span>
                    <input type="text" 
                           class="form-control" 
                           id="problematic-search" 
                           placeholder="{{ __('Buscar ruta...', 'codexroute') }}"
                           onkeyup="filterProblematicRoutes()">
                </div>
                <div class="btn-group btn-group-sm" role="group">
                    <input type="radio" class="btn-check" name="filter-problematic-status" id="filter-problematic-all" value="all" checked onchange="filterProblematicRoutes()">
                    <label class="btn btn-outline-secondary" for="filter-problematic-all">{{ __('Todas', 'codexroute') }}</label>
                    
                    <input type="radio" class="btn-check" name="filter-problematic-status" id="filter-problematic-allowed" value="allowed" onchange="filterProblematicRoutes()">
                    <label class="btn btn-outline-success" for="filter-problematic-allowed">{{ __('Permitidas', 'codexroute') }}</label>
                    
                    <input type="radio" class="btn-check" name="filter-problematic-status" id="filter-problematic-blocked" value="blocked" onchange="filterProblematicRoutes()">
                    <label class="btn btn-outline-danger" for="filter-problematic-blocked">{{ __('Bloqueadas', 'codexroute') }}</label>
                </div>
            </div>
        </div>
        <div class="card-body">
            {% if problematic_routes is empty %}
                <div class="text-center py-5">
                    <i class="ti ti-inbox fs-1 text-muted mb-3"></i>
                    <p class="text-muted">{{ __('No se encontraron rutas problemáticas', 'codexroute') }}</p>
                </div>
            {% else %}
                <div class="table-responsive">
                    <table class="table table-hover" id="problematic-routes-table">
                        <thead>
                            <tr>
                                <th style="width: 4%; min-width: 40px;">#</th>
                                <th style="width: 30%;">{{ __('Archivo', 'codexroute') }}</th>
                                <th style="width: 25%;">{{ __('Ruta', 'codexroute') }}</th>
                                <th style="width: 20%;">{{ __('Parámetros', 'codexroute') }}</th>
                                <th style="width: 12%; min-width: 120px;" class="text-center">{{ __('Estado', 'codexroute') }}</th>
                                <th style="width: 12%; min-width: 100px;" class="text-center">{{ __('Acción', 'codexroute') }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for route in problematic_routes %}
                            <tr class="problematic-route-row" 
                                data-status="{{ route.allowed ? 'allowed' : 'blocked' }}"
                                data-file="{{ route.file|lower|e }}"
                                data-path="{{ route.path|lower|e }}">
                                <td class="text-muted">{{ loop.index }}</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <i class="ti ti-file-code text-muted me-2"></i>
                                        <span class="text-truncate" style="max-width: 300px;" title="{{ route.file|e }}">
                                            <code>{{ route.file|e }}</code>
                                        </span>
                                    </div>
                                </td>
                                <td>
                                    <code class="text-primary">{{ route.path|e }}</code>
                                </td>
                                <td>
                                    <div class="d-flex flex-wrap gap-1" style="min-height: 24px;">
                                        {% for param in route.params %}
                                            <span class="badge text-white" style="background-color: #0dcaf0; white-space: nowrap; font-size: 0.7rem; padding: 0.25em 0.6em; font-weight: 500;">{{ param|e }}</span>
                                        {% endfor %}
                                    </div>
                                </td>
                                <td class="text-center" style="min-width: 120px;">
                                    {% if route.allowed %}
                                        <span class="badge text-white d-inline-flex align-items-center" style="background-color: #198754; white-space: nowrap; font-size: 0.75rem; padding: 0.4em 0.7em; font-weight: 500;">
                                            <i class="ti ti-check me-1" style="font-size: 0.85em;"></i>
                                            <span>{{ __('Permitida', 'codexroute') }}</span>
                                        </span>
                                    {% else %}
                                        <span class="badge text-white d-inline-flex align-items-center" style="background-color: #dc3545; white-space: nowrap; font-size: 0.75rem; padding: 0.4em 0.7em; font-weight: 500;">
                                            <i class="ti ti-x me-1" style="font-size: 0.85em;"></i>
                                            <span>{{ __('Bloqueada', 'codexroute') }}</span>
                                        </span>
                                    {% endif %}
                                </td>
                                <td class="text-center">
                                    {% if not route.allowed %}
                                        <button class="btn btn-sm btn-success" 
                                                onclick="allowRoute('{{ route.file|e('js') }}')"
                                                title="{{ __('Permitir esta ruta', 'codexroute') }}">
                                            <i class="ti ti-check"></i> {{ __('Permitir', 'codexroute') }}
                                        </button>
                                    {% else %}
                                        <button class="btn btn-sm btn-danger" 
                                                onclick="blockRoute('{{ route.file|e('js') }}')"
                                                title="{{ __('Bloquear esta ruta', 'codexroute') }}">
                                            <i class="ti ti-ban"></i> {{ __('Bloquear', 'codexroute') }}
                                        </button>
                                    {% endif %}
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                <div class="mt-3 pt-3 border-top">
                    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-start align-items-lg-center gap-3">
                        <div class="flex-grow-1" style="min-width: 0; writing-mode: horizontal-tb !important; text-orientation: mixed !important; direction: ltr !important;">
                            <div class="text-muted small mb-1" id="problematic-footer-text" style="writing-mode: horizontal-tb !important; text-orientation: mixed !important; direction: ltr !important; white-space: nowrap !important; display: inline-block !important; width: 100%; max-width: 100%; overflow: visible !important;">
                                <span id="problematic-count" style="display: inline !important; white-space: normal !important;">{{ problematic_routes|length }}</span> 
                                <span style="display: inline !important; white-space: normal !important;">{{ __('de', 'codexroute') }}</span> 
                                <strong style="display: inline !important; white-space: normal !important;">{{ problematic_routes|length }}</strong> 
                                <span style="display: inline !important; white-space: normal !important;">{{ __('rutas', 'codexroute') }}</span>
                            </div>
                            <div id="problematic-pagination-info" class="text-muted small" style="display: none; writing-mode: horizontal-tb !important; text-orientation: mixed !important; direction: ltr !important; white-space: nowrap !important; display: inline-block !important; width: 100%; max-width: 100%; overflow: visible !important;">
                                <span style="display: inline !important; white-space: normal !important;">{{ __('Mostrando', 'codexroute') }}</span> 
                                <span id="problematic-page-start" style="display: inline !important; white-space: normal !important;">1</span>
                                <span style="display: inline !important; white-space: normal !important;">-</span>
                                <span id="problematic-page-end" style="display: inline !important; white-space: normal !important;">{{ problematic_routes|length }}</span> 
                                <span style="display: inline !important; white-space: normal !important;">{{ __('de', 'codexroute') }}</span> 
                                <strong id="problematic-total-filtered" style="display: inline !important; white-space: normal !important;">{{ problematic_routes|length }}</strong>
                            </div>
                        </div>
                        <div class="flex-shrink-0" style="writing-mode: horizontal-tb !important; text-orientation: mixed !important; direction: ltr !important;">
                            <nav aria-label="{{ __('Paginación de rutas problemáticas', 'codexroute') }}" style="writing-mode: horizontal-tb !important; text-orientation: mixed !important; direction: ltr !important;">
                                <ul class="pagination pagination-sm mb-0" id="problematic-routes-pagination" style="writing-mode: horizontal-tb !important; text-orientation: mixed !important; direction: ltr !important;">
                                </ul>
                            </nav>
                        </div>
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
    
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h3 class="card-title mb-0">
                <i class="ti ti-check-circle"></i> 
                {{ __('Rutas Permitidas Actualmente', 'codexroute') }}
            </h3>
            <div class="d-flex gap-2">
                <div class="input-group input-group-sm" style="max-width: 250px;">
                    <span class="input-group-text"><i class="ti ti-search"></i></span>
                    <input type="text" 
                           class="form-control" 
                           id="allowed-search" 
                           placeholder="{{ __('Buscar ruta...', 'codexroute') }}"
                           onkeyup="filterAllowedRoutes()">
                </div>
            </div>
        </div>
        <div class="card-body">
            {% if allowed_routes is empty %}
                <div class="text-center py-5">
                    <i class="ti ti-inbox fs-1 text-muted mb-3"></i>
                    <p class="text-muted">{{ __('No hay rutas permitidas configuradas', 'codexroute') }}</p>
                </div>
            {% else %}
                <div class="table-responsive">
                    <table class="table table-hover" id="allowed-routes-table">
                        <thead>
                            <tr>
                                <th style="width: 4%; min-width: 40px;">#</th>
                                <th style="width: 80%;">{{ __('Archivo', 'codexroute') }}</th>
                                <th style="width: 16%; min-width: 100px;" class="text-center">{{ __('Acción', 'codexroute') }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for route in allowed_routes %}
                            <tr class="allowed-route-row" 
                                data-file="{{ route|lower|e }}">
                                <td class="text-muted">{{ loop.index }}</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <i class="ti ti-file-code text-muted me-2"></i>
                                        <span class="text-truncate" style="max-width: 600px;" title="{{ route|e }}">
                                            <code>{{ route|e }}</code>
                                        </span>
                                    </div>
                                </td>
                                <td class="text-center">
                                    <button class="btn btn-sm btn-danger" 
                                            onclick="blockRoute('{{ route|e('js') }}')"
                                            title="{{ __('Remover esta ruta de las permitidas', 'codexroute') }}">
                                        <i class="ti ti-trash"></i> {{ __('Remover', 'codexroute') }}
                                    </button>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                <div class="mt-3 pt-3 border-top">
                    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-start align-items-lg-center gap-3">
                        <div class="flex-grow-1" style="min-width: 0; writing-mode: horizontal-tb !important; text-orientation: mixed !important; direction: ltr !important;">
                            <div class="text-muted small mb-1" id="allowed-footer-text" style="writing-mode: horizontal-tb !important; text-orientation: mixed !important; direction: ltr !important; white-space: nowrap !important; display: inline-block !important; width: 100%; max-width: 100%; overflow: visible !important;">
                                <span id="allowed-count" style="display: inline !important; white-space: normal !important;">{{ allowed_routes|length }}</span> 
                                <span style="display: inline !important; white-space: normal !important;">{{ __('de', 'codexroute') }}</span> 
                                <strong style="display: inline !important; white-space: normal !important;">{{ allowed_routes|length }}</strong> 
                                <span style="display: inline !important; white-space: normal !important;">{{ __('rutas', 'codexroute') }}</span>
                            </div>
                            <div id="allowed-pagination-info" class="text-muted small" style="display: none; writing-mode: horizontal-tb !important; text-orientation: mixed !important; direction: ltr !important; white-space: nowrap !important; display: inline-block !important; width: 100%; max-width: 100%; overflow: visible !important;">
                                <span style="display: inline !important; white-space: normal !important;">{{ __('Mostrando', 'codexroute') }}</span> 
                                <span id="allowed-page-start" style="display: inline !important; white-space: normal !important;">1</span>
                                <span style="display: inline !important; white-space: normal !important;">-</span>
                                <span id="allowed-page-end" style="display: inline !important; white-space: normal !important;">{{ allowed_routes|length }}</span> 
                                <span style="display: inline !important; white-space: normal !important;">{{ __('de', 'codexroute') }}</span> 
                                <strong id="allowed-total-filtered" style="display: inline !important; white-space: normal !important;">{{ allowed_routes|length }}</strong>
                            </div>
                        </div>
                        <div class="flex-shrink-0" style="writing-mode: horizontal-tb !important; text-orientation: mixed !important; direction: ltr !important;">
                            <nav aria-label="{{ __('Paginación de rutas permitidas', 'codexroute') }}" style="writing-mode: horizontal-tb !important; text-orientation: mixed !important; direction: ltr !important;">
                                <ul class="pagination pagination-sm mb-0" id="allowed-routes-pagination" style="writing-mode: horizontal-tb !important; text-orientation: mixed !important; direction: ltr !important;">
                                </ul>
                            </nav>
                        </div>
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
</div>

<script>
// Funciones para Rutas Problemáticas
let problematicAllRows = [];
let problematicCurrentPage = 1;
const problematicItemsPerPage = 20;
let problematicAllVisibleRows = [];

function filterProblematicRoutes() {
    const searchTerm = document.getElementById('problematic-search')?.value.toLowerCase() || '';
    const filterStatus = document.querySelector('input[name="filter-problematic-status"]:checked')?.value || 'all';
    
    if (problematicAllRows.length === 0) {
        problematicAllRows = Array.from(document.querySelectorAll('#problematic-routes-table tbody .problematic-route-row'));
    }
    
    problematicAllRows.forEach(row => {
        row.style.display = 'none';
    });
    
    problematicAllVisibleRows = [];
    
    problematicAllRows.forEach((row) => {
        const file = (row.dataset.file || '').toLowerCase();
        const path = (row.dataset.path || '').toLowerCase();
        const status = row.dataset.status || '';
        
        const matchesSearch = searchTerm === '' || file.includes(searchTerm) || path.includes(searchTerm);
        const matchesFilter = filterStatus === 'all' || 
                             (filterStatus === 'allowed' && status === 'allowed') ||
                             (filterStatus === 'blocked' && status === 'blocked');
        
        if (matchesSearch && matchesFilter) {
            problematicAllVisibleRows.push(row);
        }
    });
    
    problematicCurrentPage = 1;
    updateProblematicPagination();
    displayProblematicPage();
}

function displayProblematicPage() {
    const start = (problematicCurrentPage - 1) * problematicItemsPerPage;
    const end = start + problematicItemsPerPage;
    
    problematicAllVisibleRows.forEach((row, index) => {
        if (index >= start && index < end) {
            row.style.display = '';
        } else {
            row.style.display = 'none';
        }
    });
    
    const pageStart = problematicAllVisibleRows.length > 0 ? start + 1 : 0;
    const pageEnd = Math.min(end, problematicAllVisibleRows.length);
    
    const countEl = document.getElementById('problematic-count');
    const startEl = document.getElementById('problematic-page-start');
    const endEl = document.getElementById('problematic-page-end');
    const totalEl = document.getElementById('problematic-total-filtered');
    const infoEl = document.getElementById('problematic-pagination-info');
    
    if (countEl) countEl.textContent = problematicAllVisibleRows.length;
    if (startEl) startEl.textContent = pageStart;
    if (endEl) endEl.textContent = pageEnd;
    if (totalEl) totalEl.textContent = problematicAllVisibleRows.length;
    
    if (infoEl) {
        if (problematicAllVisibleRows.length > problematicItemsPerPage) {
            infoEl.style.display = 'block';
        } else {
            infoEl.style.display = 'none';
        }
    }
}

function updateProblematicPagination() {
    const totalPages = Math.ceil(problematicAllVisibleRows.length / problematicItemsPerPage);
    const pagination = document.getElementById('problematic-routes-pagination');
    if (!pagination) return;
    
    pagination.innerHTML = '';
    
    if (totalPages <= 1) {
        return;
    }
    
    const prevLi = document.createElement('li');
    prevLi.className = `page-item ${problematicCurrentPage === 1 ? 'disabled' : ''}`;
    prevLi.innerHTML = `<a class="page-link" href="#" onclick="goToProblematicPage(${problematicCurrentPage - 1}); return false;">
        <i class="ti ti-chevron-left"></i> <span class="d-none d-sm-inline">Anterior</span>
    </a>`;
    pagination.appendChild(prevLi);
    
    const maxVisible = 5;
    let startPage = Math.max(1, problematicCurrentPage - Math.floor(maxVisible / 2));
    let endPage = Math.min(totalPages, startPage + maxVisible - 1);
    
    if (endPage - startPage < maxVisible - 1) {
        startPage = Math.max(1, endPage - maxVisible + 1);
    }
    
    if (startPage > 1) {
        const firstLi = document.createElement('li');
        firstLi.className = 'page-item';
        firstLi.innerHTML = `<a class="page-link" href="#" onclick="goToProblematicPage(1); return false;">1</a>`;
        pagination.appendChild(firstLi);
        
        if (startPage > 2) {
            const dotsLi = document.createElement('li');
            dotsLi.className = 'page-item disabled';
            dotsLi.innerHTML = `<span class="page-link">...</span>`;
            pagination.appendChild(dotsLi);
        }
    }
    
    for (let i = startPage; i <= endPage; i++) {
        const li = document.createElement('li');
        li.className = `page-item ${i === problematicCurrentPage ? 'active' : ''}`;
        li.innerHTML = `<a class="page-link" href="#" onclick="goToProblematicPage(${i}); return false;">${i}</a>`;
        pagination.appendChild(li);
    }
    
    if (endPage < totalPages) {
        if (endPage < totalPages - 1) {
            const dotsLi = document.createElement('li');
            dotsLi.className = 'page-item disabled';
            dotsLi.innerHTML = `<span class="page-link">...</span>`;
            pagination.appendChild(dotsLi);
        }
        
        const lastLi = document.createElement('li');
        lastLi.className = 'page-item';
        lastLi.innerHTML = `<a class="page-link" href="#" onclick="goToProblematicPage(${totalPages}); return false;">${totalPages}</a>`;
        pagination.appendChild(lastLi);
    }
    
    const nextLi = document.createElement('li');
    nextLi.className = `page-item ${problematicCurrentPage === totalPages ? 'disabled' : ''}`;
    nextLi.innerHTML = `<a class="page-link" href="#" onclick="goToProblematicPage(${problematicCurrentPage + 1}); return false;">
        <span class="d-none d-sm-inline">Siguiente</span> <i class="ti ti-chevron-right"></i>
    </a>`;
    pagination.appendChild(nextLi);
}

function goToProblematicPage(page) {
    const totalPages = Math.ceil(problematicAllVisibleRows.length / problematicItemsPerPage);
    if (page < 1 || page > totalPages) return;
    problematicCurrentPage = page;
    displayProblematicPage();
    updateProblematicPagination();
}

// Funciones para Rutas Permitidas
let allowedAllRows = [];
let allowedCurrentPage = 1;
const allowedItemsPerPage = 20;
let allowedAllVisibleRows = [];

function filterAllowedRoutes() {
    const searchTerm = document.getElementById('allowed-search')?.value.toLowerCase() || '';
    
    if (allowedAllRows.length === 0) {
        allowedAllRows = Array.from(document.querySelectorAll('#allowed-routes-table tbody .allowed-route-row'));
    }
    
    allowedAllRows.forEach(row => {
        row.style.display = 'none';
    });
    
    allowedAllVisibleRows = [];
    
    allowedAllRows.forEach((row) => {
        const file = (row.dataset.file || '').toLowerCase();
        
        const matchesSearch = searchTerm === '' || file.includes(searchTerm);
        
        if (matchesSearch) {
            allowedAllVisibleRows.push(row);
        }
    });
    
    allowedCurrentPage = 1;
    updateAllowedPagination();
    displayAllowedPage();
}

function displayAllowedPage() {
    const start = (allowedCurrentPage - 1) * allowedItemsPerPage;
    const end = start + allowedItemsPerPage;
    
    allowedAllVisibleRows.forEach((row, index) => {
        if (index >= start && index < end) {
            row.style.display = '';
        } else {
            row.style.display = 'none';
        }
    });
    
    const pageStart = allowedAllVisibleRows.length > 0 ? start + 1 : 0;
    const pageEnd = Math.min(end, allowedAllVisibleRows.length);
    
    const countEl = document.getElementById('allowed-count');
    const startEl = document.getElementById('allowed-page-start');
    const endEl = document.getElementById('allowed-page-end');
    const totalEl = document.getElementById('allowed-total-filtered');
    const infoEl = document.getElementById('allowed-pagination-info');
    
    if (countEl) countEl.textContent = allowedAllVisibleRows.length;
    if (startEl) startEl.textContent = pageStart;
    if (endEl) endEl.textContent = pageEnd;
    if (totalEl) totalEl.textContent = allowedAllVisibleRows.length;
    
    if (infoEl) {
        if (allowedAllVisibleRows.length > allowedItemsPerPage) {
            infoEl.style.display = 'block';
        } else {
            infoEl.style.display = 'none';
        }
    }
}

function updateAllowedPagination() {
    const totalPages = Math.ceil(allowedAllVisibleRows.length / allowedItemsPerPage);
    const pagination = document.getElementById('allowed-routes-pagination');
    if (!pagination) return;
    
    pagination.innerHTML = '';
    
    if (totalPages <= 1) {
        return;
    }
    
    const prevLi = document.createElement('li');
    prevLi.className = `page-item ${allowedCurrentPage === 1 ? 'disabled' : ''}`;
    prevLi.innerHTML = `<a class="page-link" href="#" onclick="goToAllowedPage(${allowedCurrentPage - 1}); return false;">
        <i class="ti ti-chevron-left"></i> <span class="d-none d-sm-inline">Anterior</span>
    </a>`;
    pagination.appendChild(prevLi);
    
    const maxVisible = 5;
    let startPage = Math.max(1, allowedCurrentPage - Math.floor(maxVisible / 2));
    let endPage = Math.min(totalPages, startPage + maxVisible - 1);
    
    if (endPage - startPage < maxVisible - 1) {
        startPage = Math.max(1, endPage - maxVisible + 1);
    }
    
    if (startPage > 1) {
        const firstLi = document.createElement('li');
        firstLi.className = 'page-item';
        firstLi.innerHTML = `<a class="page-link" href="#" onclick="goToAllowedPage(1); return false;">1</a>`;
        pagination.appendChild(firstLi);
        
        if (startPage > 2) {
            const dotsLi = document.createElement('li');
            dotsLi.className = 'page-item disabled';
            dotsLi.innerHTML = `<span class="page-link">...</span>`;
            pagination.appendChild(dotsLi);
        }
    }
    
    for (let i = startPage; i <= endPage; i++) {
        const li = document.createElement('li');
        li.className = `page-item ${i === allowedCurrentPage ? 'active' : ''}`;
        li.innerHTML = `<a class="page-link" href="#" onclick="goToAllowedPage(${i}); return false;">${i}</a>`;
        pagination.appendChild(li);
    }
    
    if (endPage < totalPages) {
        if (endPage < totalPages - 1) {
            const dotsLi = document.createElement('li');
            dotsLi.className = 'page-item disabled';
            dotsLi.innerHTML = `<span class="page-link">...</span>`;
            pagination.appendChild(dotsLi);
        }
        
        const lastLi = document.createElement('li');
        lastLi.className = 'page-item';
        lastLi.innerHTML = `<a class="page-link" href="#" onclick="goToAllowedPage(${totalPages}); return false;">${totalPages}</a>`;
        pagination.appendChild(lastLi);
    }
    
    const nextLi = document.createElement('li');
    nextLi.className = `page-item ${allowedCurrentPage === totalPages ? 'disabled' : ''}`;
    nextLi.innerHTML = `<a class="page-link" href="#" onclick="goToAllowedPage(${allowedCurrentPage + 1}); return false;">
        <span class="d-none d-sm-inline">Siguiente</span> <i class="ti ti-chevron-right"></i>
    </a>`;
    pagination.appendChild(nextLi);
}

function goToAllowedPage(page) {
    const totalPages = Math.ceil(allowedAllVisibleRows.length / allowedItemsPerPage);
    if (page < 1 || page > totalPages) return;
    allowedCurrentPage = page;
    displayAllowedPage();
    updateAllowedPagination();
}

// Inicialización
document.addEventListener('DOMContentLoaded', function() {
