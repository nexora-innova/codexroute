{#
 # CodexRoute - Pestaña de Permisos de Rutas
 #}

{% import 'components/alerts_macros.html.twig' as alerts %}

<div class="codexroute-plugin-pane codexroute-tab-pane d-flex flex-column gap-3" id="routes-tab">
    <div class="card card-sm">
        <div class="card-body py-3">
            {{ alerts.alert_info(
                __('Información:', 'codexroute'),
                __('Esta sección permite corregir los permisos de rutas que están siendo bloqueadas con error 403.', 'codexroute')
            ) }}
            <div class="d-flex flex-wrap gap-2 mt-3">
                <button type="button" class="btn btn-sm btn-outline-primary"
                        onclick="scanRoutes(this)"
                        title="{{ __('Re-analizar y refrescar la lista de rutas bloqueadas', 'codexroute') }}">
                    <i class="ti ti-refresh me-1"></i>{{ __('Re-analizar Rutas', 'codexroute') }}
                </button>
                {% set has_blocked = false %}
                {% for route in problematic_routes %}
                    {% if not route.allowed %}{% set has_blocked = true %}{% endif %}
                {% endfor %}
                {% if has_blocked %}
                <button type="button" class="btn btn-sm btn-success"
                        onclick="allowAllBlockedRoutes(this)"
                        title="{{ __('Permitir todas las rutas bloqueadas detectadas de una vez', 'codexroute') }}">
                    <i class="ti ti-shield-check me-1"></i>{{ __('Permitir Todas las Bloqueadas', 'codexroute') }}
                </button>
                {% endif %}
            </div>
        </div>
    </div>

    <div class="search_page codexroute-embedded-search">
        <div class="search-container disable-overflow-y">
            <div class="card card-sm mt-0 search-card">
            {% if problematic_routes is empty %}
                <div class="alert alert-info mb-0 rounded-0 border-top-0 border-bottom-0 border-end-0" role="alert">
                    {{ __('No se encontraron rutas problemáticas', 'codexroute') }}
                </div>
            {% else %}
                <div class="card-header d-flex justify-content-between search-header pe-0 flex-wrap align-items-center gap-2 py-2">
                    <h3 class="card-title mb-0 fs-5">{{ __('Rutas Problemáticas', 'codexroute') }}</h3>
                    <div class="d-flex flex-column flex-sm-row flex-wrap align-items-stretch align-items-sm-center gap-2 ms-lg-auto">
                        <div class="input-group input-group-sm flex-grow-1" style="min-width: 12rem; max-width: 100%;">
                            <span class="input-group-text" aria-hidden="true"><i class="ti ti-search"></i></span>
                            <input type="text"
                                   class="form-control"
                                   id="problematic-search"
                                   placeholder="{{ __('Buscar ruta...', 'codexroute') }}"
                                   onkeyup="filterProblematicRoutes()">
                        </div>
                        <div class="btn-group btn-group-sm flex-shrink-0" role="group" aria-label="{{ __('Filtrar por estado', 'codexroute') }}">
                            <input type="radio" class="btn-check" name="filter-problematic-status" id="filter-problematic-all" value="all" checked onchange="filterProblematicRoutes()">
                            <label class="btn btn-outline-secondary" for="filter-problematic-all">{{ __('Todas', 'codexroute') }}</label>
                            <input type="radio" class="btn-check" name="filter-problematic-status" id="filter-problematic-allowed" value="allowed" onchange="filterProblematicRoutes()">
                            <label class="btn btn-outline-success" for="filter-problematic-allowed">{{ __('Permitidas', 'codexroute') }}</label>
                            <input type="radio" class="btn-check" name="filter-problematic-status" id="filter-problematic-blocked" value="blocked" onchange="filterProblematicRoutes()">
                            <label class="btn btn-outline-danger" for="filter-problematic-blocked">{{ __('Bloqueadas', 'codexroute') }}</label>
                        </div>
                    </div>
                </div>
                <div class="table-responsive-lg">
                    <table class="search-results table card-table table-hover table-striped" id="problematic-routes-table">
                        <thead>
                            <tr>
                                <th style="width: 4%; min-width: 40px;">#</th>
                                <th>{{ __('Archivo', 'codexroute') }}</th>
                                <th>{{ __('Ruta', 'codexroute') }}</th>
                                <th>{{ __('Parámetros', 'codexroute') }}</th>
                                <th class="text-center" style="min-width: 120px;">{{ __('Estado', 'codexroute') }}</th>
                                <th class="text-center" style="min-width: 100px;">{{ __('Acción', 'codexroute') }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for route in problematic_routes %}
                            <tr class="problematic-route-row"
                                data-status="{{ route.allowed ? 'allowed' : 'blocked' }}"
                                data-file="{{ route.file|lower|e }}"
                                data-path="{{ route.path|lower|e }}">
                                <td class="text-muted">{{ loop.index }}</td>
                                <td>
                                    <span class="text-break d-inline-block mw-100" title="{{ route.file|e }}">{{ route.file|e }}</span>
                                    {% if route.detected is defined and route.detected %}
                                        <span class="badge bg-warning text-dark ms-1" title="{{ __('Detectada automáticamente por el plugin', 'codexroute') }}">
                                            <i class="ti ti-radar me-1"></i>{{ __('Detectada', 'codexroute') }}
                                        </span>
                                    {% endif %}
                                </td>
                                <td>
                                    <span class="text-break text-muted">{{ route.path|e }}</span>
                                </td>
                                <td>
                                    {% if route.params is empty %}
                                        <span class="text-muted">—</span>
                                    {% else %}
                                        <span class="text-muted">{% for param in route.params %}{{ param|e }}{% if not loop.last %}, {% endif %}{% endfor %}</span>
                                    {% endif %}
                                </td>
                                <td class="text-center" style="min-width: 120px;">
                                    {% if route.allowed %}
                                        <span class="text-success fw-medium">{{ __('Permitida', 'codexroute') }}</span>
                                    {% else %}
                                        <span class="text-danger fw-medium">{{ __('Bloqueada', 'codexroute') }}</span>
                                    {% endif %}
                                </td>
                                <td class="text-center text-nowrap">
                                    {% if not route.allowed %}
                                        <button type="button" class="btn btn-sm btn-success"
                                                onclick="allowRoute('{{ route.file|e('js') }}', this)"
                                                title="{{ __('Permitir esta ruta', 'codexroute') }}">
                                            <i class="ti ti-shield-check me-1"></i>{{ __('Permitir', 'codexroute') }}
                                        </button>
                                    {% else %}
                                        <button type="button" class="btn btn-sm btn-outline-danger"
                                                onclick="blockRoute('{{ route.file|e('js') }}', this)"
                                                title="{{ __('Bloquear esta ruta', 'codexroute') }}">
                                            <i class="ti ti-shield-x me-1"></i>{{ __('Bloquear', 'codexroute') }}
                                        </button>
                                    {% endif %}
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                <div class="card-footer search-footer">
                    {% include '@codexroute/components/codexroute_search_pager.html.twig' with {
                        prefix: 'codexroute-problematic',
                        limit_select_extra_class: 'codexroute-limit-problematic'
                    } %}
                </div>
            {% endif %}
            </div>
        </div>
    </div>

    <div class="search_page codexroute-embedded-search">
        <div class="search-container disable-overflow-y">
            <div class="card card-sm mt-0 search-card">
            {% if allowed_routes is empty %}
                <div class="alert alert-info mb-0 rounded-0 border-top-0 border-bottom-0 border-end-0" role="alert">
                    {{ __('No hay rutas permitidas configuradas', 'codexroute') }}
                </div>
            {% else %}
                <div class="card-header d-flex justify-content-between search-header pe-0 flex-wrap align-items-center gap-2 py-2">
                    <h3 class="card-title mb-0 fs-5">{{ __('Rutas Permitidas Actualmente', 'codexroute') }}</h3>
                    <div class="input-group input-group-sm flex-grow-1 flex-sm-grow-0 ms-lg-auto" style="min-width: 12rem; max-width: 100%;">
                        <span class="input-group-text" aria-hidden="true"><i class="ti ti-search"></i></span>
                        <input type="text"
                               class="form-control"
                               id="allowed-search"
                               placeholder="{{ __('Buscar ruta...', 'codexroute') }}"
                               onkeyup="filterAllowedRoutes()">
                    </div>
                </div>
                <div class="table-responsive-lg">
                    <table class="search-results table card-table table-hover table-striped" id="allowed-routes-table">
                        <thead>
                            <tr>
                                <th style="width: 4%; min-width: 40px;">#</th>
                                <th>{{ __('Archivo', 'codexroute') }}</th>
                                <th class="text-center" style="min-width: 100px;">{{ __('Acción', 'codexroute') }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for route in allowed_routes %}
                            <tr class="allowed-route-row"
                                data-file="{{ route|lower|e }}">
                                <td class="text-muted">{{ loop.index }}</td>
                                <td>
                                    <span class="text-break d-inline-block mw-100" title="{{ route|e }}">{{ route|e }}</span>
                                </td>
                                <td class="text-center text-nowrap">
                                    <button type="button" class="btn btn-sm btn-outline-danger"
                                            onclick="blockRoute('{{ route|e('js') }}', this)"
                                            title="{{ __('Remover esta ruta de las permitidas', 'codexroute') }}">
                                        <i class="ti ti-shield-x me-1"></i>{{ __('Remover', 'codexroute') }}
                                    </button>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                <div class="card-footer search-footer">
                    {% include '@codexroute/components/codexroute_search_pager.html.twig' with {
                        prefix: 'codexroute-allowed',
                        limit_select_extra_class: 'codexroute-limit-allowed'
                    } %}
                </div>
            {% endif %}
            </div>
        </div>
    </div>
</div>

{% include '@codexroute/components/codexroute_glpi_list_helpers.html.twig' %}
<script>
let problematicAllRows = [];
let problematicCurrentPage = 1;
let problematicAllVisibleRows = [];

function filterProblematicRoutes() {
    const searchTerm = document.getElementById('problematic-search')?.value.toLowerCase() || '';
    const filterStatus = document.querySelector('input[name="filter-problematic-status"]:checked')?.value || 'all';

    if (problematicAllRows.length === 0) {
        problematicAllRows = Array.from(document.querySelectorAll('#problematic-routes-table tbody .problematic-route-row'));
    }

    problematicAllRows.forEach((row) => {
        row.style.display = 'none';
    });

    problematicAllVisibleRows = [];

    problematicAllRows.forEach((row) => {
        const file = (row.dataset.file || '').toLowerCase();
        const path = (row.dataset.path || '').toLowerCase();
        const status = row.dataset.status || '';

        const matchesSearch = searchTerm === '' || file.includes(searchTerm) || path.includes(searchTerm);
        const matchesFilter = filterStatus === 'all'
            || (filterStatus === 'allowed' && status === 'allowed')
            || (filterStatus === 'blocked' && status === 'blocked');

        if (matchesSearch && matchesFilter) {
            problematicAllVisibleRows.push(row);
        }
    });

    problematicCurrentPage = 1;
    updateProblematicPagination();
    displayProblematicPage();
}

function displayProblematicPage() {
    const limit = window.codexrouteGetPageSizeForTable('problematic-routes-table');
    const start = (problematicCurrentPage - 1) * limit;
    const end = start + limit;
    const total = problematicAllVisibleRows.length;

    problematicAllVisibleRows.forEach((row, index) => {
        row.style.display = (index >= start && index < end) ? '' : 'none';
    });

    if (total === 0) {
        window.codexrouteFillPageInfos('codexroute-problematic', 0, 0, 0);
    } else {
        const pageStart = start + 1;
        const pageEnd = Math.min(end, total);
        window.codexrouteFillPageInfos('codexroute-problematic', pageStart, pageEnd, total);
    }
}

function updateProblematicPagination() {
    const limit = window.codexrouteGetPageSizeForTable('problematic-routes-table');
    const total = problematicAllVisibleRows.length;
    const totalPages = Math.max(1, Math.ceil(total / limit));
    if (problematicCurrentPage > totalPages) {
        problematicCurrentPage = totalPages;
    }
    window.codexrouteRenderGlpiPager(
        'codexroute-problematic-routes-pagination',
        problematicCurrentPage,
        totalPages,
        limit,
        'goToProblematicPage'
    );
}

function goToProblematicPage(page) {
    const limit = window.codexrouteGetPageSizeForTable('problematic-routes-table');
    const totalPages = Math.max(1, Math.ceil(problematicAllVisibleRows.length / limit));
    if (page < 1 || page > totalPages) {
        return;
    }
    problematicCurrentPage = page;
    displayProblematicPage();
    updateProblematicPagination();
}

let allowedAllRows = [];
let allowedCurrentPage = 1;
let allowedAllVisibleRows = [];

function filterAllowedRoutes() {
    const searchTerm = document.getElementById('allowed-search')?.value.toLowerCase() || '';

    if (allowedAllRows.length === 0) {
        allowedAllRows = Array.from(document.querySelectorAll('#allowed-routes-table tbody .allowed-route-row'));
    }

    allowedAllRows.forEach((row) => {
        row.style.display = 'none';
    });

    allowedAllVisibleRows = [];

    allowedAllRows.forEach((row) => {
        const file = (row.dataset.file || '').toLowerCase();
        const matchesSearch = searchTerm === '' || file.includes(searchTerm);
        if (matchesSearch) {
            allowedAllVisibleRows.push(row);
        }
    });

    allowedCurrentPage = 1;
    updateAllowedPagination();
    displayAllowedPage();
}

function displayAllowedPage() {
    const limit = window.codexrouteGetPageSizeForTable('allowed-routes-table');
    const start = (allowedCurrentPage - 1) * limit;
    const end = start + limit;
    const total = allowedAllVisibleRows.length;

    allowedAllVisibleRows.forEach((row, index) => {
        row.style.display = (index >= start && index < end) ? '' : 'none';
    });

    if (total === 0) {
        window.codexrouteFillPageInfos('codexroute-allowed', 0, 0, 0);
    } else {
        const pageStart = start + 1;
        const pageEnd = Math.min(end, total);
        window.codexrouteFillPageInfos('codexroute-allowed', pageStart, pageEnd, total);
    }
}

function updateAllowedPagination() {
    const limit = window.codexrouteGetPageSizeForTable('allowed-routes-table');
    const total = allowedAllVisibleRows.length;
    const totalPages = Math.max(1, Math.ceil(total / limit));
    if (allowedCurrentPage > totalPages) {
        allowedCurrentPage = totalPages;
    }
    window.codexrouteRenderGlpiPager(
        'codexroute-allowed-routes-pagination',
        allowedCurrentPage,
        totalPages,
        limit,
        'goToAllowedPage'
    );
}

function goToAllowedPage(page) {
    const limit = window.codexrouteGetPageSizeForTable('allowed-routes-table');
    const totalPages = Math.max(1, Math.ceil(allowedAllVisibleRows.length / limit));
    if (page < 1 || page > totalPages) {
        return;
    }
    allowedCurrentPage = page;
    displayAllowedPage();
    updateAllowedPagination();
}

function onCodexrouteRoutesLimitChange(ev) {
    if (!ev.target.classList.contains('search-limit-dropdown')) {
        return;
    }
    const card = ev.target.closest('.search-card');
    const table = card ? card.querySelector('table.search-results') : null;
    if (!table) {
        return;
    }
    const limit = parseInt(ev.target.value, 10) || 20;
    if (table.id === 'problematic-routes-table') {
        const totalPages = Math.max(1, Math.ceil(problematicAllVisibleRows.length / limit));
        if (problematicCurrentPage > totalPages) {
            problematicCurrentPage = totalPages;
        }
        updateProblematicPagination();
        displayProblematicPage();
    } else if (table.id === 'allowed-routes-table') {
        const totalPages = Math.max(1, Math.ceil(allowedAllVisibleRows.length / limit));
        if (allowedCurrentPage > totalPages) {
            allowedCurrentPage = totalPages;
        }
        updateAllowedPagination();
        displayAllowedPage();
    }
}

document.addEventListener('DOMContentLoaded', function() {
    document.getElementById('routes-tab')?.addEventListener('change', onCodexrouteRoutesLimitChange);

    if (document.getElementById('problematic-routes-table')) {
        problematicAllRows = Array.from(document.querySelectorAll('#problematic-routes-table tbody .problematic-route-row'));
        filterProblematicRoutes();
    }

    if (document.getElementById('allowed-routes-table')) {
        allowedAllRows = Array.from(document.querySelectorAll('#allowed-routes-table tbody .allowed-route-row'));
        filterAllowedRoutes();
    }
});
</script>

