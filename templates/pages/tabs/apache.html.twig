{#
 # CodexRoute - Pestaña de Rendimiento Apache/PHP
 #}

<div class="tab-pane fade show active" id="apache-tab">
    <div class="card mb-3">
        <div class="card-header">
            <h3 class="card-title mb-0">
                <i class="ti ti-dashboard"></i> 
                {{ __('Configuración PHP', 'codexroute') }}
            </h3>
        </div>
        <div class="card-body">
            <div class="row g-3 mb-4">
                <div class="col-lg-3 col-md-6 col-sm-6">
                    <div class="card border-0 shadow-sm h-100 border-start border-primary border-4">
                        <div class="card-body p-3">
                            <div class="d-flex align-items-start mb-3">
                                <div class="flex-shrink-0">
                                    <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 64px; height: 64px;">
                                        <i class="ti ti-brand-php" style="font-size: 1.75rem;"></i>
                                    </div>
                                </div>
                                <div class="flex-grow-1 ms-3">
                                    <div class="text-dark fw-semibold mb-1" style="font-size: 0.875rem; line-height: 1.3;">{{ __('Versión PHP', 'codexroute') }}</div>
                                    <div class="mb-0 text-primary fw-bold" style="font-size: 1.5rem; line-height: 1.2;">{{ php_info.version }}</div>
                                </div>
                            </div>
                            <div class="text-muted" style="font-size: 0.8rem; line-height: 1.4;">
                                <i class="ti ti-info-circle"></i> 
                                <span>{{ __('Versión actual de PHP', 'codexroute') }}</span>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="col-lg-3 col-md-6 col-sm-6">
                    <div class="card border-0 shadow-sm h-100 border-start border-{{ (php_info.memory_limit_numeric ?? 0) >= 256 ? 'success' : 'warning' }} border-4">
                        <div class="card-body p-3">
                            <div class="d-flex align-items-start mb-3">
                                <div class="flex-shrink-0">
                                    <div class="bg-{{ (php_info.memory_limit_numeric ?? 0) >= 256 ? 'success' : 'warning' }} text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 64px; height: 64px;">
                                        <i class="ti ti-device-desktop" style="font-size: 1.75rem;"></i>
                                    </div>
                                </div>
                                <div class="flex-grow-1 ms-3">
                                    <div class="text-dark fw-semibold mb-1" style="font-size: 0.875rem; line-height: 1.3;">{{ __('Memory Limit', 'codexroute') }}</div>
                                    <div class="mb-0 text-{{ (php_info.memory_limit_numeric ?? 0) >= 256 ? 'success' : 'warning' }} fw-bold" style="font-size: 1.5rem; line-height: 1.2;">{{ php_info.memory_limit }}</div>
                                </div>
                            </div>
                            <div class="text-muted" style="font-size: 0.8rem; line-height: 1.4;">
                                <i class="ti ti-{{ (php_info.memory_limit_numeric ?? 0) >= 256 ? 'check' : 'alert-triangle' }}"></i> 
                                <span>{{ (php_info.memory_limit_numeric ?? 0) >= 256 ? __('Memoria suficiente', 'codexroute') : __('Memoria limitada', 'codexroute') }}</span>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="col-lg-3 col-md-6 col-sm-6">
                    <div class="card border-0 shadow-sm h-100 border-start border-info border-4">
                        <div class="card-body p-3">
                            <div class="d-flex align-items-start mb-3">
                                <div class="flex-shrink-0">
                                    <div class="bg-info text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 64px; height: 64px;">
                                        <i class="ti ti-clock" style="font-size: 1.75rem;"></i>
                                    </div>
                                </div>
                                <div class="flex-grow-1 ms-3">
                                    <div class="text-dark fw-semibold mb-1" style="font-size: 0.875rem; line-height: 1.3;">{{ __('Max Execution Time', 'codexroute') }}</div>
                                    <div class="mb-0 text-info fw-bold" style="font-size: 1.5rem; line-height: 1.2;">{{ php_info.max_execution_time }}s</div>
                                </div>
                            </div>
                            <div class="text-muted" style="font-size: 0.8rem; line-height: 1.4;">
                                <i class="ti ti-info-circle"></i> 
                                <span>{{ __('Tiempo máximo de ejecución', 'codexroute') }}</span>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="col-lg-3 col-md-6 col-sm-6">
                    <div class="card border-0 shadow-sm h-100 border-start border-{{ php_info.opcache_enabled ? 'success' : 'warning' }} border-4">
                        <div class="card-body p-3">
                            <div class="d-flex align-items-start mb-3">
                                <div class="flex-shrink-0">
                                    <div class="bg-{{ php_info.opcache_enabled ? 'success' : 'warning' }} text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 64px; height: 64px;">
                                        <i class="ti ti-bolt" style="font-size: 1.75rem;"></i>
                                    </div>
                                </div>
                                <div class="flex-grow-1 ms-3">
                                    <div class="text-dark fw-semibold mb-1" style="font-size: 0.875rem; line-height: 1.3;">{{ __('OPcache', 'codexroute') }}</div>
                                    <div class="mb-0 text-{{ php_info.opcache_enabled ? 'success' : 'warning' }} fw-bold" style="font-size: 1.25rem; line-height: 1.2;">
                                        {% if php_info.opcache_enabled %}
                                            {{ __('Habilitado', 'codexroute') }}
                                        {% else %}
                                            {{ __('Deshabilitado', 'codexroute') }}
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                            <div class="text-muted" style="font-size: 0.8rem; line-height: 1.4;">
                                <i class="ti ti-{{ php_info.opcache_enabled ? 'check' : 'x' }}"></i> 
                                <span>{{ php_info.opcache_enabled ? __('Optimización activa', 'codexroute') : __('Optimización inactiva', 'codexroute') }}</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="card mb-3">
        <div class="card-header">
            <h3 class="card-title mb-0">
                <i class="ti ti-puzzle"></i> 
                {{ __('Extensiones PHP', 'codexroute') }}
            </h3>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-lg-3 col-md-6 col-sm-6">
                    <div class="card border-0 shadow-sm h-100 border-start border-{{ php_info.sodium_available ? 'success' : 'danger' }} border-4">
                        <div class="card-body p-3">
                            <div class="d-flex align-items-start mb-3">
                                <div class="flex-shrink-0">
                                    <div class="bg-{{ php_info.sodium_available ? 'success' : 'danger' }} text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 64px; height: 64px;">
                                        <i class="ti ti-shield" style="font-size: 1.75rem;"></i>
                                    </div>
                                </div>
                                <div class="flex-grow-1 ms-3">
                                    <div class="text-dark fw-semibold mb-1" style="font-size: 0.875rem; line-height: 1.3;">{{ __('Sodium', 'codexroute') }}</div>
                                    <div class="mb-0 text-{{ php_info.sodium_available ? 'success' : 'danger' }} fw-bold" style="font-size: 1.25rem; line-height: 1.2;">
                                        {% if php_info.sodium_available %}
                                            {{ __('Disponible', 'codexroute') }}
                                        {% else %}
                                            {{ __('No disponible', 'codexroute') }}
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                            <div class="text-muted" style="font-size: 0.8rem; line-height: 1.4;">
                                <i class="ti ti-{{ php_info.sodium_available ? 'check' : 'x' }}"></i> 
                                <span>{{ php_info.sodium_available ? __('Encriptación disponible', 'codexroute') : __('Encriptación no disponible', 'codexroute') }}</span>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="col-lg-3 col-md-6 col-sm-6">
                    <div class="card border-0 shadow-sm h-100 border-start border-{{ php_info.openssl_available ? 'success' : 'danger' }} border-4">
                        <div class="card-body p-3">
                            <div class="d-flex align-items-start mb-3">
                                <div class="flex-shrink-0">
                                    <div class="bg-{{ php_info.openssl_available ? 'success' : 'danger' }} text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 64px; height: 64px;">
                                        <i class="ti ti-lock" style="font-size: 1.75rem;"></i>
                                    </div>
                                </div>
                                <div class="flex-grow-1 ms-3">
                                    <div class="text-dark fw-semibold mb-1" style="font-size: 0.875rem; line-height: 1.3;">{{ __('OpenSSL', 'codexroute') }}</div>
                                    <div class="mb-0 text-{{ php_info.openssl_available ? 'success' : 'danger' }} fw-bold" style="font-size: 1.25rem; line-height: 1.2;">
                                        {% if php_info.openssl_available %}
                                            {{ __('Disponible', 'codexroute') }}
                                        {% else %}
                                            {{ __('No disponible', 'codexroute') }}
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                            <div class="text-muted" style="font-size: 0.8rem; line-height: 1.4;">
                                <i class="ti ti-{{ php_info.openssl_available ? 'check' : 'x' }}"></i> 
                                <span>{{ php_info.openssl_available ? __('SSL/TLS disponible', 'codexroute') : __('SSL/TLS no disponible', 'codexroute') }}</span>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="col-lg-3 col-md-6 col-sm-6">
                    <div class="card border-0 shadow-sm h-100 border-start border-{{ php_info.mbstring_available ? 'success' : 'danger' }} border-4">
                        <div class="card-body p-3">
                            <div class="d-flex align-items-start mb-3">
                                <div class="flex-shrink-0">
                                    <div class="bg-{{ php_info.mbstring_available ? 'success' : 'danger' }} text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 64px; height: 64px;">
                                        <i class="ti ti-code" style="font-size: 1.75rem;"></i>
                                    </div>
                                </div>
                                <div class="flex-grow-1 ms-3">
                                    <div class="text-dark fw-semibold mb-1" style="font-size: 0.875rem; line-height: 1.3;">{{ __('mbstring', 'codexroute') }}</div>
                                    <div class="mb-0 text-{{ php_info.mbstring_available ? 'success' : 'danger' }} fw-bold" style="font-size: 1.25rem; line-height: 1.2;">
                                        {% if php_info.mbstring_available %}
                                            {{ __('Disponible', 'codexroute') }}
                                        {% else %}
                                            {{ __('No disponible', 'codexroute') }}
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                            <div class="text-muted" style="font-size: 0.8rem; line-height: 1.4;">
                                <i class="ti ti-{{ php_info.mbstring_available ? 'check' : 'x' }}"></i> 
                                <span>{{ php_info.mbstring_available ? __('Multibyte strings disponible', 'codexroute') : __('Multibyte strings no disponible', 'codexroute') }}</span>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="col-lg-3 col-md-6 col-sm-6">
                    <div class="card border-0 shadow-sm h-100 border-start border-{{ php_info.curl_available ? 'success' : 'danger' }} border-4">
                        <div class="card-body p-3">
                            <div class="d-flex align-items-start mb-3">
                                <div class="flex-shrink-0">
                                    <div class="bg-{{ php_info.curl_available ? 'success' : 'danger' }} text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 64px; height: 64px;">
                                        <i class="ti ti-world" style="font-size: 1.75rem;"></i>
                                    </div>
                                </div>
                                <div class="flex-grow-1 ms-3">
                                    <div class="text-dark fw-semibold mb-1" style="font-size: 0.875rem; line-height: 1.3;">{{ __('cURL', 'codexroute') }}</div>
                                    <div class="mb-0 text-{{ php_info.curl_available ? 'success' : 'danger' }} fw-bold" style="font-size: 1.25rem; line-height: 1.2;">
                                        {% if php_info.curl_available %}
                                            {{ __('Disponible', 'codexroute') }}
                                        {% else %}
                                            {{ __('No disponible', 'codexroute') }}
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                            <div class="text-muted" style="font-size: 0.8rem; line-height: 1.4;">
                                <i class="ti ti-{{ php_info.curl_available ? 'check' : 'x' }}"></i> 
                                <span>{{ php_info.curl_available ? __('HTTP requests disponible', 'codexroute') : __('HTTP requests no disponible', 'codexroute') }}</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="card mb-3">
        <div class="card-header">
            <h3 class="card-title mb-0">{{ __('Acciones', 'codexroute') }}</h3>
        </div>
        <div class="card-body">
            <div class="d-flex gap-2">
                <button class="btn btn-primary" onclick="executeAction('analyze_apache')">
                    <i class="ti ti-analyze"></i> {{ __('Analizar Rendimiento Apache/PHP', 'codexroute') }}
                </button>
            </div>
        </div>
    </div>
    
    <div class="card" id="apache-results" style="display: none;">
        <div class="card-header">
            <h3 class="card-title mb-0">{{ __('Resultados del Análisis', 'codexroute') }}</h3>
        </div>
        <div class="card-body" id="apache-results-content">
        </div>
    </div>
</div>

