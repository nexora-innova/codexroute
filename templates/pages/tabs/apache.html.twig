{#
 # CodexRoute - Rendimiento Apache/PHP
 #}

<div class="codexroute-plugin-pane codexroute-tab-pane d-flex flex-column gap-3" id="apache-tab">
    <div class="card card-sm search-card">
        <div class="card-header py-2">
            <h3 class="card-title mb-0 fs-5">{{ __('Configuración PHP', 'codexroute') }}</h3>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive-md">
                <table class="table table-hover table-card mb-0">
                    <tbody>
                        <tr>
                            <th class="w-25 text-muted fw-normal">{{ __('Versión PHP', 'codexroute') }}</th>
                            <td><code>{{ php_info.version|e }}</code></td>
                        </tr>
                        <tr>
                            <th class="text-muted fw-normal">{{ __('Memory Limit', 'codexroute') }}</th>
                            <td>{{ php_info.memory_limit|e }}</td>
                        </tr>
                        <tr>
                            <th class="text-muted fw-normal">{{ __('Max Execution Time', 'codexroute') }}</th>
                            <td>{{ php_info.max_execution_time|e }}s</td>
                        </tr>
                        <tr>
                            <th class="text-muted fw-normal">{{ __('OPcache', 'codexroute') }}</th>
                            <td>
                                {% if php_info.opcache_enabled %}
                                    <span class="badge bg-success">{{ __('Habilitado', 'codexroute') }}</span>
                                {% else %}
                                    <span class="badge bg-secondary text-white">{{ __('Deshabilitado', 'codexroute') }}</span>
                                {% endif %}
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="card card-sm search-card">
        <div class="card-header py-2">
            <h3 class="card-title mb-0 fs-5">{{ __('Extensiones PHP', 'codexroute') }}</h3>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive-md">
                <table class="table table-hover table-card mb-0">
                    <thead>
                        <tr>
                            <th>{{ __('Extensión', 'codexroute') }}</th>
                            <th class="text-center">{{ __('Estado', 'codexroute') }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><code>sodium</code></td>
                            <td class="text-center">
                                {% if php_info.sodium_available %}
                                    <span class="badge bg-success">{{ __('Disponible', 'codexroute') }}</span>
                                {% else %}
                                    <span class="badge bg-secondary text-white">{{ __('No disponible', 'codexroute') }}</span>
                                {% endif %}
                            </td>
                        </tr>
                        <tr>
                            <td><code>openssl</code></td>
                            <td class="text-center">
                                {% if php_info.openssl_available %}
                                    <span class="badge bg-success">{{ __('Disponible', 'codexroute') }}</span>
                                {% else %}
                                    <span class="badge bg-secondary text-white">{{ __('No disponible', 'codexroute') }}</span>
                                {% endif %}
                            </td>
                        </tr>
                        <tr>
                            <td><code>mbstring</code></td>
                            <td class="text-center">
                                {% if php_info.mbstring_available %}
                                    <span class="badge bg-success">{{ __('Disponible', 'codexroute') }}</span>
                                {% else %}
                                    <span class="badge bg-secondary text-white">{{ __('No disponible', 'codexroute') }}</span>
                                {% endif %}
                            </td>
                        </tr>
                        <tr>
                            <td><code>curl</code></td>
                            <td class="text-center">
                                {% if php_info.curl_available %}
                                    <span class="badge bg-success">{{ __('Disponible', 'codexroute') }}</span>
                                {% else %}
                                    <span class="badge bg-secondary text-white">{{ __('No disponible', 'codexroute') }}</span>
                                {% endif %}
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="card card-sm">
        <div class="card-header py-2">
            <h3 class="card-title mb-0 fs-5">{{ __('Acciones', 'codexroute') }}</h3>
        </div>
        <div class="card-body">
            <button type="button" class="btn btn-primary" onclick="executeAction('analyze_apache', {}, this)">
                {{ __('Analizar Rendimiento Apache/PHP', 'codexroute') }}
            </button>
        </div>
    </div>

    <div class="card card-sm d-none" id="apache-results">
        <div class="card-header py-2">
            <h3 class="card-title mb-0 fs-5">{{ __('Resultados del Análisis', 'codexroute') }}</h3>
        </div>
        <div class="card-body p-0" id="apache-results-content"></div>
    </div>
</div>
