{#
 # CodexRoute - Configuración (pestañas verticales como ficha GLPI: Ajax::createTabs orientation vertical)
 #}

{% set active_tab = active_tab|default(ordered_tabs[0].key) %}

<div class="container-fluid px-2 px-md-3 codexroute-admin-panel" id="codexroute-admin-root">
    <div class="d-flex justify-content-end mb-2">
        <div class="dropdown">
            <button class="btn btn-outline-secondary btn-sm dropdown-toggle"
                    type="button"
                    data-bs-toggle="dropdown"
                    aria-expanded="false"
                    title="{{ __('Options', 'codexroute') }}">
                <i class="ti ti-adjustments-horizontal me-1"></i>{{ __('Options', 'codexroute') }}
            </button>
            <ul class="dropdown-menu dropdown-menu-end">
                <li>
                    <button type="button" class="dropdown-item codexroute-toggle-order">
                        <i class="ti ti-arrows-sort me-2"></i>{{ __('Reorder tabs', 'codexroute') }}
                    </button>
                </li>
            </ul>
        </div>
    </div>

    <div id="codexroute-main-layout" class="d-flex card-tabs flex-column flex-md-row vertical w-100">
        <ul class="nav nav-tabs flex-row flex-md-column d-none d-md-block"
            id="tabspanel"
            style="min-width: 200px"
            role="tablist">
            {% for tab in ordered_tabs %}
                {% set is_active = active_tab == tab.key %}
                {% set completion = tabs_completion[tab.key] %}
                <li class="nav-item" role="presentation">
                    <a href="?tab={{ tab.key }}"
                       class="nav-link pe-md-1 {{ is_active ? 'active' : '' }}"
                       {{ is_active ? 'aria-current="page"' : '' }}
                       role="tab"
                       data-tab-key="{{ tab.key }}"
                       {% if completion.completed %}title="{{ __('Completed', 'codexroute') }}"{% endif %}>
                        {{ tab.title }}
                        {% if completion.completed %}
                            <span class="visually-hidden"> — {{ __('Completed', 'codexroute') }}</span>
                        {% endif %}
                    </a>
                </li>
            {% endfor %}
        </ul>

        <select class="form-select d-md-none mb-2 rounded-0 rounded-top"
                id="codexroute-mobile-tab-select"
                aria-label="{{ __('Section', 'codexroute') }}">
            {% for tab in ordered_tabs %}
                <option value="{{ tab.key }}" {{ active_tab == tab.key ? 'selected' : '' }}>{{ tab.title }}</option>
            {% endfor %}
        </select>

        <div class="tab-content p-2 flex-grow-1 card border-start-0" style="min-height: 150px;">
            {% if active_tab == 'routes' %}
                {% include '@codexroute/pages/tabs/routes.html.twig' with {
                    'problematic_routes': problematic_routes,
                    'allowed_routes': allowed_routes
                } %}
            {% elseif active_tab == 'config' %}
                {% include '@codexroute/pages/tabs/config.html.twig' with {
                    'encryption_config': encryption_config
                } %}
            {% elseif active_tab == 'apache' %}
                {% include '@codexroute/pages/tabs/apache.html.twig' with {
                    'php_info': php_info
                } %}
            {% elseif active_tab == 'database' %}
                {% include '@codexroute/pages/tabs/database.html.twig' with {
                    'db_status': db_status,
                    'optimizable_tables': optimizable_tables,
                    'glpi_list_limit': glpi_list_limit|default(20)
                } %}
            {% endif %}
        </div>
    </div>

    <div class="card card-sm mt-3 d-none" id="tabs-order-panel">
        <div class="card-header">
            <h3 class="card-title mb-0">{{ __('Reorder tabs', 'codexroute') }}</h3>
        </div>
        <div class="card-body">
            <p class="text-muted small mb-3">{{ __('Drag is not required: use the arrows to change order, then save.', 'codexroute') }}</p>
            <div class="list-group list-group-flush border rounded" id="tabs-order-list">
                {% for tab in ordered_tabs %}
                    <div class="list-group-item d-flex align-items-center" data-tab-key="{{ tab.key }}">
                        <i class="ti ti-grip-vertical text-muted me-2" aria-hidden="true"></i>
                        <span class="flex-grow-1">{{ tab.title }}</span>
                        <div class="btn-group btn-group-sm">
                            <button type="button"
                                    class="btn btn-outline-secondary codexroute-tab-move-up"
                                    data-codexroute-tab="{{ tab.key }}"
                                    {{ loop.first ? 'disabled' : '' }}
                                    title="{{ __('Move up', 'codexroute') }}">
                                <i class="ti ti-arrow-up"></i>
                            </button>
                            <button type="button"
                                    class="btn btn-outline-secondary codexroute-tab-move-down"
                                    data-codexroute-tab="{{ tab.key }}"
                                    {{ loop.last ? 'disabled' : '' }}
                                    title="{{ __('Move down', 'codexroute') }}">
                                <i class="ti ti-arrow-down"></i>
                            </button>
                        </div>
                    </div>
                {% endfor %}
            </div>
            <div class="d-flex flex-wrap gap-2 mt-3">
                <button type="button" class="btn btn-primary codexroute-save-tabs-order">
                    <i class="ti ti-device-floppy me-1"></i>{{ __('Save order', 'codexroute') }}
                </button>
                <button type="button" class="btn btn-outline-secondary codexroute-reset-tabs-order">
                    <i class="ti ti-rotate-clockwise me-1"></i>{{ __('Restore', 'codexroute') }}
                </button>
                <button type="button" class="btn btn-ghost-secondary codexroute-toggle-order">
                    {{ __('Cancel', 'codexroute') }}
                </button>
            </div>
        </div>
    </div>
</div>

<script type="application/json" id="codexroute-admin-tabs-json">{{ {
    'active_tab': active_tab,
    'tabs_order': tabs_order_keys
}|json_encode|raw }}</script>
